{
  "server": {
    "port": {{ garnet_port }},
    "bind": "0.0.0.0"
  },
  "storage": {
    "type": "appendonly",
    "appendonly": true,
    "appendfsync": "everysec",
    "dir": "/var/lib/garnet",
    "dbfilename": "dump.rdb"
  },
  "persistence": {
    "bgsave": true,
    "bgsave_interval": 300
  }
}
