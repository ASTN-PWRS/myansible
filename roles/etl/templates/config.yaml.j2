# Database connection
db: "{{ etl_db_name }}"
user: "{{ etl_db_user }}"
password: "{{ etl_db_password }}"
host: "{{ etl_db_host }}"
port: "{{ etl_db_port | default('5432') }}"

# Path to the daily CSV file
csv_path: "{{ etl_csv_path }}"

# Logging settings
log_file: "{{ etl_log_file | default('/var/log/etl.log') }}"
log_level: "{{ etl_log_level | default('INFO') }}"
