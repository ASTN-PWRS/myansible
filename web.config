<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Windows 統合認証 -->
    <security>
      <authentication>
        <windowsAuthentication enabled="true" />
        <anonymousAuthentication enabled="false" />
      </authentication>
    </security>

    <!-- URL Rewrite + 認証ユーザー転送 -->
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNginx" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:{{ nginx_port }}/n/{R:1}" />

          <!-- 認証済ユーザー名をヘッダに追加 -->
          <serverVariables>
            <set name="HTTP_X_AUTH_USER" value="{LOGON_USER}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- Reverse Proxy 有効化 -->
    <proxy>
      <reverseProxy enabled="true" />
    </proxy>

  </system.webServer>
</configuration>
